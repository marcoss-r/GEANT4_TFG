    </element>
  <element name="Ca_element" Z="20" formula="Ca">
      <atom value="40.078"/>
    </element>
  <element name="Al_element" Z="13" formula="Al">
      <atom value="26.9815384"/>
    </element>
  <element name="H_element" Z="1" formula="H">
      <atom value="1.008"/>
    </element>
  <material name="G4_Al" formula="Al">
      <D unit="g/cm3" value="2.699"/>
    <composite n="1" ref="Al_element"/>
    </material>
  <material name="G4_CONCRETE" formula="G4_CONCRETE">
      <D unit="g/cm3" value="2.3"/>
    <fraction n="0.01" ref="H_element"/>
    <fraction n="0.001" ref="C_element"/>
    <fraction n="0.529107" ref="O_element"/>
    <fraction n="0.016" ref="Na_element"/>
    <fraction n="0.002" ref="Mg_element"/>
    <fraction n="0.033872" ref="Al_element"/>
    <fraction n="0.337021" ref="Si_element"/>
    <fraction n="0.013" ref="K_element"/>
    <fraction n="0.044" ref="Ca_element"/>
    <fraction n="0.014" ref="Fe_element"/>
    </material>
  <material name="G4_AIR" formula="G4_AIR">
      <D unit="g/cm3" value="0.00120479"/>
    <fraction n="0.000124" ref="C_element"/>
    <fraction n="0.755268" ref="N_element"/>
    <fraction n="0.231781" ref="O_element"/>
    <fraction n="0.012827" ref="Ar_element"/>
    </material>
  </materials>
<solids>
    <box name="WorldBox" x="20.0" y="200.0" z="20.0" lunit="m"/>
  <box name="Box" x="6.0" y="0.2" z="6.0" lunit="m"/>
  <box name="Box001" x="0.3" y="4.0" z="8.0" lunit="m"/>
  <box name="Box002" x="0.3" y="4.0" z="8.0" lunit="m"/>
