  <box name="Box005" x="8.0" y="0.3" z="8.0" lunit="m"/>
  <box name="physRoof003" x="5.05" y="0.3" z="8.0" lunit="m"/>
  <box name="physRoof004" x="5.1" y="0.3" z="8.0" lunit="m"/>
  <union name="Fuse">
      <first ref="physRoof003"/>
    <second ref="physRoof004"/>
    <position name="P-GDMLBox_Box0077" unit="mm" x="3276.6081771559693" y="-2294.3057454041846"/>
    <rotation name="R-GDMLBox_Box0071" unit="deg" z="-70.00000000000003"/>
    </union>
  </solids>
<structure>
